                "from statsmodels.tsa.stattools import adfuller",
                "from statsmodels.tsa.statespace.sarimax import SARIMAX",
                "import torch",
                "import torch.nn as nn",
                "from torch.utils.data import DataLoader, TensorDataset",
                "import warnings",
